# Base URL of the backend gRPC gateway / API the browser talks to
NEXT_PUBLIC_API_URL=http://localhost:50051

# Google OAuth2 (public client id used to start the sign-in flow)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=000000000000-example.apps.googleusercontent.com

# Public site URL (used to build OAuth redirect URIs)
NEXT_PUBLIC_APP_URL=http://localhost:3000
