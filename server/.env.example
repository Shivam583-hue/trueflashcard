# gRPC server listen address
GRPC_ADDRESS=:50051

# HTTP server (Connect API + OAuth) port. The host (e.g. Render) sets PORT;
# when unset it falls back to 8080. The server always binds 0.0.0.0.
PORT=8080

# NeonDB / Postgres connection string (parameterized queries only)
DATABASE_URL=postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/flashcards?sslmode=require

# Google OAuth2 (server-side token exchange).
# The redirect URL must point at this backend's callback and be
# registered in the Google Cloud console.
GOOGLE_CLIENT_ID=000000000000-example.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-exampledummysecret
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/google/callback

# Frontend origin: used for the post-login redirect and CORS allow-list
APP_URL=http://localhost:3000

# Set to "true" to mark session cookies Secure (required in production over HTTPS)
COOKIE_SECURE=false

# Set to "none" when the frontend and API are on different sites (e.g. Vercel
# frontend + a separate API domain) so the session cookie is sent on cross-site
# requests. "none" forces Secure. Leave unset for same-site/local dev (Lax).
COOKIE_SAMESITE=lax

# Session / JWT signing (use a long random string in production)
JWT_SECRET=replace-with-a-long-random-string
