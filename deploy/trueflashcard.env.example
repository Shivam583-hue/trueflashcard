# Copy to /etc/trueflashcard.env on the VPS and fill in real values.
# systemd reads this literally (no shell expansion), so the Neon URL's
# & characters are fine unquoted.

PORT=8080

# Neon Postgres (the same DB you used in dev is already migrated)
DATABASE_URL=postgresql://user:password@ep-xxxx.aws.neon.tech/flashcards?sslmode=require

# Long random string
JWT_SECRET=replace-with-a-long-random-string

# Google OAuth — redirect URL must match what's registered in the Google console
GOOGLE_CLIENT_ID=000000000000-example.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-example
GOOGLE_REDIRECT_URL=https://api.nemportfolio.in/auth/google/callback

# Frontend origin (used for the post-login redirect and CORS allow-list)
APP_URL=https://ryugacards.vercel.app

# Cross-site cookie settings: frontend (Vercel) and API (tunnel) are different
# sites, so the session cookie must be SameSite=None; Secure.
COOKIE_SECURE=true
COOKIE_SAMESITE=none
